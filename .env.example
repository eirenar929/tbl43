# =============================================================================
# Пример переменных окружения для "Столик на троих"
# Скопируйте в .env и заполните своими значениями
# =============================================================================

# =============================================================================
# API Keys для моделей
# =============================================================================

# OpenAI (GPT-4, GPT-3.5)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# OpenAI Moderation API (опционально, для модерации)
OPENAI_MODERATION_KEY=sk-your-moderation-key-here

# =============================================================================
# Настройки приложения
# =============================================================================

# Порт для запуска
APP_PORT=8000

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# Настройки модерации
# =============================================================================

# Порог чувствительности модерации (0.0 - 1.0)
MODERATION_THRESHOLD=0.7

# =============================================================================
# Настройки workflow
# =============================================================================

# Таймаут ожидания ответов от моделей (секунды)
RESPONSE_TIMEOUT=10.0

# Минимальное количество ответов для отправки пользователю
MIN_RESPONSES=1

# Стратегия форматирования ответов: concat, first, compare, best
RESPONSE_STRATEGY=compare
